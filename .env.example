# Browser calls same-origin /api/v1; Vite dev server proxies to the backend (no browser CORS).
VITE_API_BASE_URL=/api/v1

# Local Docker + Traefik (default)
# VITE_API_PROXY_TARGET=http://localhost

# Remote Droplet (167.172.77.110) / domain — use HTTPS domain (Traefik TLS):
VITE_API_PROXY_TARGET=https://collabspace.ngocanh2005it.site

# Or raw IP (HTTP only, if Traefik serves :80 without redirect):
# VITE_API_PROXY_TARGET=http://167.172.77.110

# Do NOT set VITE_API_BASE_URL to a remote https URL in dev — protected routes
# fail CORS preflight and may cause "Failed to fetch" or unexpected logouts.
